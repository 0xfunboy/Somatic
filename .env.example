# Latent Somatic — environment configuration template
# Copy to .env and fill in real values.
# .env is in .gitignore and must never be committed.

# ── Sensor provider ──────────────────────────────────────────────────────────
SOMA_SENSOR_PROVIDER=linux
# SOMA_SENSOR_PROVIDER=mock

# ── LLM ─────────────────────────────────────────────────────────────────────
SOMA_LLM_MODE=deepseek
# SOMA_LLM_MODE=openai
# SOMA_LLM_MODE=gemrouter
# SOMA_LLM_MODE=off

SOMA_DEEPSEEK_API_KEY=
SOMA_OPENAI_API_KEY=
SOMA_GEMROUTER_API_KEY=

SOMA_LLM_TIMEOUT_SEC=30
SOMA_REFLECTION_INTERVAL_SEC=600
SOMA_GOAL_UPDATE_INTERVAL_SEC=30
SOMA_SPONTANEOUS_SPEECH_COOLDOWN_SEC=90

# ── Volitional core ──────────────────────────────────────────────────────────
SOMA_VOLITION=1
SOMA_COGNITIVE_TRACE=1
SOMA_TICK_HZ=2
SOMA_COGNITIVE_TICK_HZ=5
SOMA_MIND_PULSE_SEC=30
SOMA_GROWTH_EVAL_INTERVAL_SEC=120
SOMA_AUTOBIOGRAPHY_MIN_INTERVAL_SEC=300

# ── Autonomy (off by default) ────────────────────────────────────────────────
SOMA_AUTONOMY_UNLOCKED=0
SOMA_DISCOVERY=0
SOMA_CAPABILITY_LEARNING=0
SOMA_SHELL_EXEC=0
SOMA_SELF_MODIFY=0
SOMA_CNS_PULSE=0

# ── Survival envelope ────────────────────────────────────────────────────────
SOMA_SYSTEM_PACKAGE_MUTATION=0
SOMA_COMMAND_TIMEOUT_SEC=30
SOMA_MAX_COMMAND_OUTPUT_CHARS=12000
SOMA_MAX_WRITE_MB=256
SOMA_MIN_FREE_DISK_GB=5.0
SOMA_MAX_CPU_LOAD_FOR_HEAVY_TASK=6.0
SOMA_MAX_MEMORY_PERCENT_FOR_HEAVY_TASK=85.0

# ── Phase 6: Trace persistence ────────────────────────────────────────────────
# off | important | all
SOMA_TRACE_PERSISTENCE=important
SOMA_TRACE_HOT_MAX_MB=10
SOMA_TRACE_ARCHIVE_GZIP=1

# ── Phase 6: Actuation deduplication ─────────────────────────────────────────
SOMA_ACTUATION_HISTORY_MIN_INTERVAL_SEC=30

# ── Phase 6: Journal ─────────────────────────────────────────────────────────
SOMA_JOURNAL_ENABLED=1
SOMA_JOURNAL_HOT_MAX_MB=25
SOMA_JOURNAL_COMPACT_AT_MB=50

# ── Phase 6: Autobiography ────────────────────────────────────────────────────
SOMA_AUTOBIOGRAPHY_ENABLED=1

# ── Phase 6: Slow routines ────────────────────────────────────────────────────
SOMA_ROUTINES_ENABLED=1
SOMA_ROUTINE_MIN_INTERVAL_SEC=300
SOMA_ROUTINE_IDLE_ONLY=1
SOMA_ROUTINE_MAX_PER_HOUR=6

# ── Phase 6: Nightly reflection ────────────────────────────────────────────────
SOMA_NIGHTLY_REFLECTION=1
SOMA_NIGHTLY_HOUR=3
SOMA_NIGHTLY_MINUTE=30
SOMA_NIGHTLY_REQUIRE_IDLE=1
SOMA_NIGHTLY_COMPACT_LOGS=1
SOMA_NIGHTLY_USE_LLM=1

# ── Phase 6: Self-improvement ─────────────────────────────────────────────────
SOMA_SELF_IMPROVEMENT_ENABLED=1
SOMA_SELF_IMPROVEMENT_AUTO_APPLY=0
SOMA_SELF_IMPROVEMENT_AUTO_ROLLBACK=1
SOMA_SELF_IMPROVEMENT_MAX_FILES=5
SOMA_SELF_IMPROVEMENT_MAX_DIFF_LINES=500
SOMA_SELF_IMPROVEMENT_REQUIRE_TESTS=1

# ── Phase 8: BIOS loop ───────────────────────────────────────────────────────
SOMA_BIOS_LOOP=1
SOMA_BIOS_INTERVAL_SEC=300
SOMA_BIOS_IDLE_ONLY=0
SOMA_BIOS_USE_LLM=1
SOMA_BIOS_MAX_TASKS_PER_HOUR=12
SOMA_BIOS_MAX_LLM_CALLS_PER_HOUR=12
SOMA_BIOS_TASK_TIMEOUT_SEC=60
SOMA_BIOS_WRITE_MEMORY=1
SOMA_BIOS_MUTATION_PROPOSAL_INTERVAL_SEC=1800

# ── Phase 8: Mutation sandbox ────────────────────────────────────────────────
SOMA_MUTATION_SANDBOX=1
SOMA_MUTATION_ROOT=/home/funboy/latent-somatic-mutants
SOMA_MUTATION_AUTO_APPLY=0
SOMA_MUTATION_AUTO_CREATE_SANDBOX=1
SOMA_MUTATION_MAX_PER_DAY=3
SOMA_MUTATION_REQUIRE_OPERATOR_APPROVAL_FOR_MIGRATION=1
SOMA_MUTATION_RUN_TESTS=1
SOMA_MUTATION_SMOKE_TEST=1
SOMA_MUTATION_SANDBOX_WS_PORT=8875
SOMA_MUTATION_SANDBOX_HTTP_PORT=8880

# ── Phase 8: C++ bridge ──────────────────────────────────────────────────────
SOMA_CPP_BRIDGE=1
SOMA_CPP_BINARY=/home/funboy/latent-somatic/build/latent_somatic
SOMA_CPP_AUTO_BUILD=0
SOMA_CPP_SMOKE_TEST_ON_START=1
SOMA_CPP_USE_FOR_PROJECTION=0
SOMA_CPP_LLAMA_CPP_ROOT=/home/funboy/llama.cpp
