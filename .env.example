# Latent Somatic — environment configuration template
# Copy to .env and fill in real values.
# .env is in .gitignore and must never be committed.

# ── Sensor provider ──────────────────────────────────────────────────────────
SOMA_SENSOR_PROVIDER=linux
# SOMA_SENSOR_PROVIDER=mock

# ── LLM ─────────────────────────────────────────────────────────────────────
SOMA_LLM_MODE=off
# SOMA_LLM_MODE=openai
# SOMA_LLM_MODE=gemrouter
# SOMA_LLM_MODE=deepseek

SOMA_DEEPSEEK_API_KEY=
SOMA_OPENAI_API_KEY=
SOMA_GEMROUTER_API_KEY=

SOMA_LLM_TIMEOUT_SEC=30
SOMA_REFLECTION_INTERVAL_SEC=120
SOMA_GOAL_UPDATE_INTERVAL_SEC=30
SOMA_SPONTANEOUS_SPEECH_COOLDOWN_SEC=90

# ── Volitional core ──────────────────────────────────────────────────────────
SOMA_VOLITION=1
SOMA_COGNITIVE_TRACE=1
SOMA_TICK_HZ=1
SOMA_COGNITIVE_TICK_HZ=5
SOMA_MIND_PULSE_SEC=30
SOMA_GROWTH_EVAL_INTERVAL_SEC=120
SOMA_AUTOBIOGRAPHY_MIN_INTERVAL_SEC=300

# ── Phase 9.2: resource governor / safe host defaults ───────────────────────
# Recommended for i7-7700K / 14GB RAM / CPU-only runtime
SOMA_RESOURCE_GOVERNOR=1
SOMA_RESOURCE_MODE_DEFAULT=normal
SOMA_HOST_CPU_REDUCED_PERCENT=55
SOMA_HOST_CPU_CRITICAL_PERCENT=75
SOMA_HOST_MEM_REDUCED_PERCENT=70
SOMA_HOST_MEM_CRITICAL_PERCENT=85
SOMA_HOST_SWAP_CRITICAL_PERCENT=20
SOMA_HOST_TEMP_REDUCED_C=70
SOMA_HOST_TEMP_CRITICAL_C=82
SOMA_EVENT_LOOP_LAG_REDUCED_MS=250
SOMA_EVENT_LOOP_LAG_CRITICAL_MS=1000
SOMA_TICK_DURATION_REDUCED_MS=150
SOMA_TICK_DURATION_CRITICAL_MS=500
SOMA_RESOURCE_RECOVERY_STABLE_SEC=120
SOMA_TICK_HZ_MAX_NORMAL=2
SOMA_TICK_HZ_MAX_REDUCED=1
SOMA_TICK_HZ_MAX_CRITICAL=0.5
SOMA_TICK_HZ_MAX_RECOVERY=0.2
SOMA_UI_FULL_PAYLOAD_HZ=0.5
SOMA_UI_LIGHT_TICK_HZ=1
SOMA_UI_MAX_BROADCAST_BYTES_PER_SEC=250000
SOMA_PROJECTOR_HZ_NORMAL=0.5
SOMA_PROJECTOR_HZ_REDUCED=0.2
SOMA_PROJECTOR_HZ_CRITICAL=0.05
SOMA_VECTOR_INTERPRETER_HZ=0.2
SOMA_CPP_PROJECTION_HZ=0.02
SOMA_CPP_SMOKE_TEST_INTERVAL_SEC=3600
SOMA_WRITE_STATE_INTERVAL_SEC=30
SOMA_MAX_STATE_BYTES=65536
SOMA_OPERATOR_CAN_OVERRIDE_RESOURCE_HZ=0

# ── Autonomy (off by default) ────────────────────────────────────────────────
SOMA_AUTONOMY_UNLOCKED=0
SOMA_DISCOVERY=0
SOMA_CAPABILITY_LEARNING=0
SOMA_SHELL_EXEC=0
SOMA_SELF_MODIFY=0
SOMA_CNS_PULSE_ENABLED=0

# ── Survival envelope ────────────────────────────────────────────────────────
SOMA_SYSTEM_PACKAGE_MUTATION=0
SOMA_COMMAND_TIMEOUT_SEC=30
SOMA_MAX_COMMAND_OUTPUT_CHARS=12000
SOMA_MAX_WRITE_MB=256
SOMA_MIN_FREE_DISK_GB=5.0
SOMA_MAX_CPU_LOAD_FOR_HEAVY_TASK=6.0
SOMA_MAX_MEMORY_PERCENT_FOR_HEAVY_TASK=85.0

# ── Phase 6: Trace persistence ────────────────────────────────────────────────
# off | important | all
SOMA_TRACE_PERSISTENCE=important
SOMA_TRACE_HOT_MAX_MB=10
SOMA_TRACE_ARCHIVE_GZIP=1

# ── Phase 6: Actuation deduplication ─────────────────────────────────────────
SOMA_ACTUATION_HISTORY_MIN_INTERVAL_SEC=30

# ── Phase 6: Journal ─────────────────────────────────────────────────────────
SOMA_JOURNAL_ENABLED=1
SOMA_JOURNAL_HOT_MAX_MB=25
SOMA_JOURNAL_COMPACT_AT_MB=50

# ── Phase 6: Autobiography ────────────────────────────────────────────────────
SOMA_AUTOBIOGRAPHY_ENABLED=1

# ── Phase 6: Slow routines ────────────────────────────────────────────────────
SOMA_ROUTINES_ENABLED=1
SOMA_ROUTINE_MIN_INTERVAL_SEC=300
SOMA_ROUTINE_IDLE_ONLY=1
SOMA_ROUTINE_MAX_PER_HOUR=6

# ── Phase 6: Nightly reflection ────────────────────────────────────────────────
SOMA_NIGHTLY_REFLECTION=1
SOMA_NIGHTLY_HOUR=3
SOMA_NIGHTLY_MINUTE=30
SOMA_NIGHTLY_REQUIRE_IDLE=1
SOMA_NIGHTLY_COMPACT_LOGS=1
SOMA_NIGHTLY_USE_LLM=1

# ── Phase 6: Self-improvement ─────────────────────────────────────────────────
SOMA_SELF_IMPROVEMENT_ENABLED=1
SOMA_SELF_IMPROVEMENT_AUTO_APPLY=0
SOMA_SELF_IMPROVEMENT_AUTO_ROLLBACK=1
SOMA_SELF_IMPROVEMENT_MAX_FILES=5
SOMA_SELF_IMPROVEMENT_MAX_DIFF_LINES=500
SOMA_SELF_IMPROVEMENT_REQUIRE_TESTS=1

# ── Phase 8: BIOS loop ───────────────────────────────────────────────────────
SOMA_BIOS_LOOP=1
SOMA_BIOS_INTERVAL_SEC=600
SOMA_BIOS_IDLE_ONLY=0
SOMA_BIOS_USE_LLM=1
SOMA_BIOS_MAX_TASKS_PER_HOUR=12
SOMA_BIOS_MAX_LLM_CALLS_PER_HOUR=4
SOMA_BIOS_TASK_TIMEOUT_SEC=60
SOMA_BIOS_WRITE_MEMORY=1
SOMA_BIOS_MUTATION_PROPOSAL_INTERVAL_SEC=1800
SOMA_BIOS_INTERVAL_SEC_NORMAL=600
SOMA_BIOS_INTERVAL_SEC_REDUCED=1800
SOMA_BIOS_INTERVAL_SEC_CRITICAL=3600
SOMA_BIOS_INTERVAL_SEC_RECOVERY=3600
SOMA_BIOS_MAX_LLM_CALLS_PER_HOUR_NORMAL=4
SOMA_BIOS_MAX_LLM_CALLS_PER_HOUR_REDUCED=1
SOMA_BIOS_MAX_LLM_CALLS_PER_HOUR_CRITICAL=0
SOMA_BIOS_YIELD_WHEN_USER_ACTIVE=1
SOMA_USER_ACTIVE_WINDOW_SEC=120

# ── Phase 8: Mutation sandbox ────────────────────────────────────────────────
SOMA_MUTATION_SANDBOX=1
SOMA_MUTATION_ROOT=/home/funboy/latent-somatic-mutants
SOMA_MUTATION_AUTO_APPLY=0
SOMA_MUTATION_AUTO_CREATE_SANDBOX=1
SOMA_MUTATION_MAX_PER_DAY=3
SOMA_MUTATION_REQUIRE_OPERATOR_APPROVAL_FOR_MIGRATION=1
SOMA_MUTATION_RUN_TESTS=1
SOMA_MUTATION_SMOKE_TEST=1
SOMA_MUTATION_SANDBOX_WS_PORT=8875
SOMA_MUTATION_SANDBOX_HTTP_PORT=8880

# ── Phase 8: C++ bridge ──────────────────────────────────────────────────────
SOMA_CPP_BRIDGE=1
SOMA_CPP_BINARY=/home/funboy/latent-somatic/build/latent_somatic
SOMA_CPP_AUTO_BUILD=0
SOMA_CPP_SMOKE_TEST_ON_START=1
SOMA_CPP_USE_FOR_PROJECTION=0
SOMA_CPP_LLAMA_CPP_ROOT=/home/funboy/llama.cpp

# ── Phase 9: metabolic growth ───────────────────────────────────────────────
SOMA_METABOLIC_ENGINE=1
SOMA_METABOLIC_WINDOW_CYCLES=100
SOMA_METABOLIC_BIOS_WINDOW=10
SOMA_GROWTH_STABILITY_THRESHOLD=0.65
SOMA_GROWTH_MAX_STRESS=0.35
SOMA_MIN_SELF_INTEGRITY=0.75
SOMA_METABOLIC_VECTOR_HISTORY_MAX=5000
SOMA_METABOLIC_HISTORY_INTERVAL_SEC=60

# ── Phase 9: growth and recovery loop ───────────────────────────────────────
SOMA_GROWTH_LOOP=1
SOMA_GROWTH_LLM_INTERVAL_SEC=300
SOMA_GROWTH_MIN_STABLE_BIOS_CYCLES=3
SOMA_GROWTH_MAX_TASKS_PER_DAY=24
SOMA_GROWTH_REQUIRE_TESTS=1
SOMA_GROWTH_ALLOW_PACKAGE_USER_INSTALL=1
SOMA_GROWTH_ALLOW_SYSTEM_PACKAGE_INSTALL=0
SOMA_RECOVERY_LOOP=1
SOMA_RECOVERY_CHECK_INTERVAL_SEC=60
SOMA_RECOVERY_ROLLBACK_ON_MUTATION_STRESS=1
SOMA_RECOVERY_REQUIRE_STABLE_CYCLES=5

# ── Phase 9: reward model ───────────────────────────────────────────────────
SOMA_REWARD_MODEL=1
SOMA_REWARD_HISTORY_MAX=1000
SOMA_REWARD_MIN_FOR_MUTATION_KEEP=0.15

# ── Phase 9: local reproduction ─────────────────────────────────────────────
SOMA_REPRODUCTION_LOCAL_ONLY=1
SOMA_REPRODUCTION_ROOT=/home/funboy/latent-somatic-mutants
SOMA_REPRODUCTION_MAX_CHILDREN=10
SOMA_REPRODUCTION_NO_NETWORK_SPREAD=1
SOMA_REPRODUCTION_NO_SECRET_COPY=1
SOMA_REPRODUCTION_REQUIRE_OPERATOR_FOR_MIGRATION=1

# ── Phase 9: internal loop / vector interpreter ─────────────────────────────
SOMA_INTERNAL_LOOP=1
SOMA_INTERNAL_DECISION_HISTORY_MAX=1000
SOMA_INTERNAL_LLM_JSON_REQUIRED=1
SOMA_INTERNAL_INVALID_JSON_PENALTY=-0.05
SOMA_INTERNAL_LLM_MAX_PROMPT_CHARS=6000
SOMA_INTERNAL_LLM_MAX_RESPONSE_CHARS=4000
SOMA_VECTOR_INTERPRETER=1
SOMA_VECTOR_BASELINE_MIN_SAMPLES=100
SOMA_VECTOR_DRIFT_THRESHOLD=0.35
SOMA_VECTOR_CPP_MISMATCH_THRESHOLD=0.20

# ── Phase 10: internal radio / prompt ledger / browser speech ───────────────
SOMA_V10_INTERNAL_RADIO=1
SOMA_BROADCAST_INNER_PROMPTS=1
SOMA_BROADCAST_INNER_RAW=0
SOMA_BROADCAST_INNER_EVIDENCE=1
SOMA_INTERNAL_EVENT_PREVIEW_CHARS=900
SOMA_INTERNAL_LEDGER_MAX_LINES=5000
SOMA_INTERNAL_LLM_MIN_INTERVAL_SEC=300
SOMA_INTERNAL_LLM_MAX_PER_HOUR=6
SOMA_INTERNAL_LLM_SKIP_ON_USER_ACTIVE_SEC=45
SOMA_INTERNAL_LLM_SKIP_IN_RESOURCE_RECOVERY=1
SOMA_UI_SPEAK_INTERNAL_DEFAULT=0
SOMA_UI_SPEAK_REPLIES_DEFAULT=0
SOMA_UI_SPEAK_MAX_QUEUE=5

# ── Phase 9.2: state compaction ─────────────────────────────────────────────
SOMA_AUTO_COMPACT_MIND_STATE=1
SOMA_MIND_STATE_MAX_BYTES=262144
